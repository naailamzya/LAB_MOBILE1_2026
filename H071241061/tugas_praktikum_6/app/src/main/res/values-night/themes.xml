<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Praktikum6" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccent</item>

        <!-- Background/Surface colors -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>

        <!-- Custom attributes -->
        <item name="colorBackground">@color/background_dark</item>
        <item name="colorOnBackground">@color/on_surface_dark</item>
        <item name="colorSurfaceVariant">#49454F</item>
        <item name="colorOnSurfaceVariant">#CAC4D0</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.Praktikum6.Splash" parent="Theme.Praktikum6">
        <item name="android:windowBackground">@color/colorPrimaryDark</item>
    </style>

</resources>
